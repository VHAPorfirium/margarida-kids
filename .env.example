# ─── Copie este arquivo para .env.local (dev) ou .env.production ────────────
#
# DEV LOCAL (npx supabase start → copie os valores exibidos):
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
#
# PRODUCAO (Supabase dashboard → Settings → API):
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ─── EMAIL (Resend) ─────────────────────────────────
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=Margarida Kids <noreply@seudominio.com.br>
NEXT_PUBLIC_APP_URL=https://seudominio.com.br

# Admin auth (independente do Supabase GoTrue)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
